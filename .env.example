# Clara Automation — required environment variables
# Copy this file to .env and fill in your keys.

GROQ_API_KEY=gsk_your_groq_key_here
RETELL_API_KEY=your_retell_api_key_here

# Optional — Asana integration (task creation after pipelines)
ASANA_ACCESS_TOKEN=
ASANA_PROJECT_GID=

# Optional — fallback model directory (default: ./models)
# Set automatically in Docker via docker-compose.yml
# MODELS_DIR=/app/models
